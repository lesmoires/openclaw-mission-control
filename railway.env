# ============================================
# RAILWAY ENV - Option A: Supabase Existant
# ============================================

# --- Authentification ---
AUTH_MODE=local
LOCAL_AUTH_TOKEN=change_me_50_chars_minimum

# --- DATABASE (Supabase Moira Rose Existant) ---
# Utilise la même DB que PG on Rails, schéma isolé
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres.railway.internal:5432/railway
# Le backend créera automatiquement le schéma 'mission_control'

# --- REDIS (Optionnel - sans queue synchrone) ---
# Si pas de Redis, on désactive les workers/async
RQ_REDIS_URL=  # Laisser vide pour mode synchrone

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_URL=ws://gateway.railway.internal:18789
OPENCLAW_GATEWAY_TOKEN=${OPENCLAW_GATEWAY_TOKEN}

# --- CORS ---
CORS_ORIGINS=*

# --- Logging ---
LOG_LEVEL=INFO

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://${RAILWAY_PUBLIC_DOMAIN}/api
NEXT_PUBLIC_AUTH_MODE=local
